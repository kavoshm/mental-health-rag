# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# OpenAI / LLM Configuration
# ---------------------------------------------------------------------------

# OpenAI API key for embeddings and LLM calls (required for OpenAI-based features)
# Get your OpenAI API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# LLM model name for summarization and chat (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini

# LLM temperature for response generation (default: 0.0, range: 0.0-2.0)
LLM_TEMPERATURE=0.0

# ---------------------------------------------------------------------------
# Embedding Configuration
# ---------------------------------------------------------------------------

# Embedding model used for document and query embeddings (default: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Text Splitting Configuration
# ---------------------------------------------------------------------------

# Maximum number of characters per text chunk (default: 1200)
CHUNK_SIZE=1200

# Number of overlapping characters between consecutive chunks (default: 200)
CHUNK_OVERLAP=200
